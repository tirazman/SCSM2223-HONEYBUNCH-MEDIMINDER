{
    "name": "tiraz/server",
    "description": "MediMinder Slim 4 Backend API",
    "type": "project",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "slim/slim": "^4.13",
        "slim/psr7": "^1.7",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^6.10",
        "jimtools/jwt-auth": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "slim/configurable": true
        }
    }
}